<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Finvoice Log Tree View -->
        <record id="view_finvoice_log_tree" model="ir.ui.view">
            <field name="name">finvoice.log.tree</field>
            <field name="model">finvoice.log</field>
            <field name="priority">8</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="invoice_id"/>
                    <field name="recipient_name"/>
                    <field name="status" widget="badge" decoration-success="status == 'delivered'" decoration-warning="status == 'sent'" decoration-danger="status == 'failed'"/>
                    <field name="sent_date"/>
                    <field name="delivery_date"/>
                </tree>
            </field>
        </record>

        <!-- Finvoice Log Form View -->
        <record id="view_finvoice_log_form" model="ir.ui.view">
            <field name="name">finvoice.log.form</field>
            <field name="model">finvoice.log</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button 
                            name="check_status_from_maventa" 
                            type="object" 
                            string="Refresh Status" 
                            class="oe_highlight"
                            attrs="{'invisible': [('maventa_id', '=', False)]}"
                        />
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="invoice_id" readonly="1"/>
                                <field name="company_id" readonly="1"/>
                                <field name="status" widget="badge" decoration-success="status == 'delivered'" decoration-warning="status == 'sent'" decoration-danger="status == 'failed'"/>
                            </group>
                            <group>
                                <field name="recipient_name" readonly="1"/>
                                <field name="recipient_id" readonly="1"/>
                                <field name="maventa_id" readonly="1"/>
                            </group>
                        </group>

                        <group string="Timestamps">
                            <field name="create_date" readonly="1"/>
                            <field name="sent_date" readonly="1"/>
                            <field name="delivery_date" readonly="1"/>
                            <field name="last_status_check" readonly="1"/>
                        </group>

                        <group string="Finvoice XML" context="{'readonly': True}">
                            <field name="finvoice_xml" readonly="1" nolabel="1"/>
                        </group>

                        <group string="Error Information" attrs="{'invisible': [('error_message', '=', False)]}">
                            <field name="error_message" readonly="1" nolabel="1"/>
                        </group>

                        <group string="API Response">
                            <field name="api_response" readonly="1" nolabel="1"/>
                        </group>

                        <group>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Finvoice Log Search View -->
        <record id="view_finvoice_log_search" model="ir.ui.view">
            <field name="name">finvoice.log.search</field>
            <field name="model">finvoice.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="invoice_id"/>
                    <field name="recipient_name"/>
                    <field name="recipient_id"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="Pending" name="pending" domain="[('status', '=', 'pending')]"/>
                    <filter string="Sent" name="sent" domain="[('status', '=', 'sent')]"/>
                    <filter string="Delivered" name="delivered" domain="[('status', '=', 'delivered')]"/>
                    <filter string="Failed" name="failed" domain="[('status', '=', 'failed')]"/>
                    <separator/>
                    <filter string="This Month" name="this_month" domain="[('create_date', '>=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')), ('create_date', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                </search>
            </field>
        </record>

        <!-- Finvoice Log Action -->
        <record id="action_finvoice_log" model="ir.actions.act_window">
            <field name="name">Finvoice Logs</field>
            <field name="res_model">finvoice.log</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    View Finvoice transmission logs
                </p>
            </field>
        </record>
    </data>
</odoo>
