<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Account Move Form View Extension -->
        <record id="view_move_form_finvoice" model="ir.ui.view">
            <field name="name">account.move.form.finvoice</field>
            <field name="model">account.move</field>
            <field name="inherit_id">account.view_move_form</field>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_post']" position="after">
                    <button 
                        name="action_send_finvoice" 
                        type="object"
                        string="Send Finvoice"
                        class="oe_highlight"
                        attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}"
                    />
                    <button 
                        name="action_check_finvoice_status" 
                        type="object"
                        string="Check Finvoice Status"
                        attrs="{'invisible': [('finvoice_status', '=', 'not_sent')]}"
                    />
                </xpath>

                <xpath expr="//field[@name='ref']" position="after">
                    <field 
                        name="finvoice_status" 
                        widget="badge" 
                        decoration-info="finvoice_status == 'not_sent'"
                        decoration-warning="finvoice_status == 'pending'"
                        decoration-success="finvoice_status == 'sent'"
                        decoration-danger="finvoice_status == 'failed'"
                    />
                    <field name="send_finvoice" attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}"/>
                </xpath>

                <xpath expr="//field[@name='narration']" position="after">
                    <field 
                        name="finvoice_error" 
                        readonly="1" 
                        nolabel="0"
                        widget="text"
                        attrs="{'invisible': [('finvoice_error', '=', False)]}"
                    />
                </xpath>

                <xpath expr="//page[@name='invoice_tab']" position="after">
                    <page string="Finvoice" name="finvoice_page" attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}">
                        <group>
                            <field name="finvoice_recipients" widget="many2many_tags"/>
                        </group>
                        
                        <group string="Transmission Logs">
                            <field name="finvoice_logs" nolabel="1" readonly="1">
                                <tree>
                                    <field name="recipient_name"/>
                                    <field name="status" widget="badge"/>
                                    <field name="sent_date"/>
                                    <field name="delivery_date"/>
                                </tree>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
